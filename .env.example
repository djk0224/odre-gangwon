# Show pitch demo banner on home (set true for presentations)
NEXT_PUBLIC_SHOW_PITCH_DEMO=false

# =============================================================================
# Vercel 배포 — 필수 환경 변수
# =============================================================================
# NEXT_PUBLIC_* 는 빌드 시 주입됩니다. Vercel에 추가·변경 후 Redeploy 필요.
# 서버 전용 키(KAKAO_REST, PUBLIC_DATA, GEMINI 등)는 재배포 없이 런타임 반영.
#
# 공공데이터포털 키: 디코딩(일반) 키를 권장합니다. URL 인코딩 키도 코드에서 처리합니다.

# --- 내 메뉴 시연 로그인 ---
# 복수 계정: username:password:표시이름 을 ; 로 구분
DEMO_AUTH_ACCOUNTS=odre:your-password:ODRÉ 시연;odre1:your-password:ODRÉ 시연
# (선택) 단일 계정 레거시 — DEMO_AUTH_ACCOUNTS 와 병합
DEMO_AUTH_USERNAME=odre
DEMO_AUTH_PASSWORD=
DEMO_AUTH_DISPLAY_NAME=ODRÉ 시연

# --- Kakao (지도·경로) ---
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=
KAKAO_REST_API_KEY=

# --- 공공데이터 (관광 GW·기상·TAGO) ---
PUBLIC_DATA_PORTAL_SERVICE_KEY=
TOUR_API_SERVICE_KEY=

# --- AI (선택 — 없으면 규칙 fallback) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- 오드레 노트 뉴스 (선택) ---
NAVER_NEWS_CLIENT_ID=
NAVER_NEWS_CLIENT_SECRET=

# =============================================================================
# 로컬 개발 / 선택
# =============================================================================

# Production: stay/dining tabs require live APIs (no mock fallback)
# NEXT_PUBLIC_ALLOW_RESERVATION_MOCK=true

# 음식점(강원 CSV API): bundle src/data/imported/gangwon-restaurants-*.json (npm run import:data)

# 한국관광 데이터랩 · 관광빅데이터 GW (5종 API — TOUR/PUBLIC 키와 동일 인증키 사용 가능)
# DATA_LAB_API_KEY=  # 선택: 별도 키가 있을 때만. 없으면 TOUR_API_SERVICE_KEY fallback

# 소상공인시장진흥공단 상가정보
SBIZ_SERVICE_KEY=

# 강원특별자치도 오픈API (음식점·숙박 등)
GANGWON_OPEN_API_KEY=

# 기상청 단기예보
WEATHER_API_SERVICE_KEY=

# 국토교통부 TAGO (버스 도착·노선)
TAGO_SERVICE_KEY=

# RAG 하이브리드 검색 (npm run build:rag / npm run build:rag:full)
GEMINI_EMBED_MODEL=gemini-embedding-001
# BUILD_RAG_FULL=1

# Optional map providers
NAVER_MAP_CLIENT_ID=
NAVER_MAP_CLIENT_SECRET=
# 오드레 노트 뉴스 스크랩 시작일 (선택 — 미설정 시 날짜 제한 없음)
# ODRE_NOTE_NEWS_SINCE=2026-06-01
TMAP_API_KEY=
